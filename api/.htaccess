Options -Indexes
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "DENY"

# Block direct access to config
<FilesMatch "^(database|helpers)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow PHP files only
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ - [L,R=404]
